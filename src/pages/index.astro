<style is:inline>
:root{
  --navy:#13233a;
  --navy-soft:#1d304c;
  --gold:#c8ad73;
  --cream:#f7f3eb;
  --linen:#efe8dc;
  --text:#22302b;
  --muted:#6d736c;
  --line:#ddd4c4;
}

*{
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  margin:0;
  background:var(--cream);
  color:var(--text);
  font-family:Georgia, "Times New Roman", serif;
}

a{
  color:inherit;
  text-decoration:none;
}

.hero{
  background:
  linear-gradient(
      135deg,
      rgba(19,35,58,.98),
      rgba(29,48,76,.92)
  );
  color:white;
}

.nav{
  max-width:1300px;
  margin:auto;
  padding:34px 40px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.brand{
  display:flex;
  align-items:center;
  gap:14px;
}

.monogram{
  width:42px;
  height:42px;
  border:1px solid rgba(200,173,115,.7);
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--gold);
  font-size:22px;
}

.brand-name{
  letter-spacing:.25em;
  font-size:12px;
  font-weight:bold;
}

.hero-inner{
  max-width:1300px;
  margin:auto;
  padding:120px 40px 140px;
}

.kicker{
  color:var(--gold);
  letter-spacing:.25em;
  text-transform:uppercase;
  font-size:12px;
  margin-bottom:22px;
}

h1{
  max-width:900px;
  margin:0 0 30px;
  font-size:78px;
  line-height:.95;
  font-weight:400;
}

.hero-copy{
  max-width:720px;
  font-size:24px;
  line-height:1.7;
  color:rgba(255,255,255,.86);
}

.buttons{
  margin-top:40px;
  display:flex;
  gap:16px;
  flex-wrap:wrap;
}

.btn{
  padding:16px 28px;
  font-size:15px;
}

.btn-primary{
  background:var(--gold);
  color:var(--navy);
}

.btn-secondary{
  border:1px solid rgba(255,255,255,.4);
}

.section{
  max-width:1300px;
  margin:auto;
  padding:110px 40px;
}

.two-col{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:90px;
}

.label{
  color:var(--gold);
  text-transform:uppercase;
  letter-spacing:.2em;
  font-size:12px;
  margin-bottom:16px;
}

h2{
  margin:0;
  color:var(--navy);
  font-size:58px;
  line-height:1.05;
  font-weight:400;
}

.body-copy p{
  font-size:22px;
  line-height:1.8;
  color:var(--muted);
}

.band{
  background:var(--linen);
}

.cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:28px;
  margin-top:50px;
}

.card{
  background:white;
  border:1px solid var(--line);
  padding:40px;
}

.card h3{
  color:var(--navy);
  font-size:30px;
  font-weight:400;
}

.card p{
  color:var(--muted);
  line-height:1.8;
}

.quote{
  background:var(--navy);
  color:white;
  text-align:center;
  padding:120px 40px;
}

.quote p{
  max-width:1100px;
  margin:auto;
  font-size:56px;
  line-height:1.25;
}

.contact-box{
  background:var(--linen);
  padding:48px;
  border:1px solid var(--line);
}

.contact-box p{
  color:var(--muted);
  line-height:1.8;
  font-size:20px;
}

footer{
  background:var(--navy);
  color:rgba(255,255,255,.65);
  padding:30px 40px;
  display:flex;
  justify-content:space-between;
}

@media(max-width:900px){

  h1{
    font-size:52px;
  }

  h2{
    font-size:42px;
  }

  .two-col,
  .cards{
    grid-template-columns:1fr;
  }

  footer{
    flex-direction:column;
    gap:10px;
  }
}
</style>

</head>

